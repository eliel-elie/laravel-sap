{
    "name": "elielelie/laravel-sap",
    "description": "SAP features integrated with Laravel.",
    "keywords": [
        "php",
        "laravel",
        "driver",
        "SAP"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Elielelie\\Sap\\": "src/"
        }
    },
	"autoload-dev": {
        "psr-4": {
            "Elielelie\\Sap\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Eliel Ferreira",
            "email": "eliel_elie@hotmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10 || ^11 || ^12",
        "illuminate/console": "^10 || ^11 || ^12"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elielelie\\Sap\\SapServiceProvider"
            ],
            "aliases": {
                "Sap": "Elielelie\\Sap\\Facades\\Sap"
            }
        }
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "pestphp/pest": "^4.4",
        "mockery/mockery": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:dox": "vendor/bin/pest --testdox",
        "lint": "vendor/bin/pint --test",
        "format": "vendor/bin/pint"
    }
}
